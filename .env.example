# WalletRadar environment variables
# Copy this file to .env and fill in your values:  cp .env.example .env

# Ankr Premium RPC API key (https://www.ankr.com/rpc/)
# Without this key, Ankr endpoints fall back to free tier (lower rate limits).
ANKR_API_KEY=

# drpc.org api key
DRPC_API_KEY=

# MongoDB connection URI
MONGODB_URI=mongodb://localhost:27017/walletradar

# Explorer API keys (optional; leave empty for no-key usage where supported).
ETHEREUM_ETHERSCAN_API_KEY=
ARBITRUM_ETHERSCAN_API_KEY=
POLYGON_ETHERSCAN_API_KEY=
MANTLE_ETHERSCAN_API_KEY=

ETHEREUM_BLOCKSCOUT_API_KEY=
ARBITRUM_BLOCKSCOUT_API_KEY=
OPTIMISM_BLOCKSCOUT_API_KEY=
BASE_BLOCKSCOUT_API_KEY=
POLYGON_BLOCKSCOUT_API_KEY=
