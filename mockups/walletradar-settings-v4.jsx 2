.ifield{width:100%;background:${C.s2};border:1px solid ${C.border};border-radius:6px;
  color:${C.text};padding:8px 11px;font-size:12px;font-family:'IBM Plex Mono',monospace;
  transition:border-color .12s,box-shadow .12s}
.ifield:focus{border-color:${C.cyanMid};box-shadow:0 0 0 3px ${C.cyanDim}}
.ifield.ok{border-color:${C.green}50}.ifield.err{border-color:${C.red}50}

.toggle{position:relative;display:inline-block;width:30px;height:17px;flex-shrink:0}
.toggle input{opacity:0;width:0;height:0}
