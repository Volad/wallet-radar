const shortA = a => `${a.slice(0,6)}…${a.slice(-4)}`;
const NETS = [
  {id:"ETH", icon:"⟠",label:"Ethereum", color:"#627EEA"},
  {id:"ARB", icon:"△",label:"Arbitrum", color:"#28A0F0"},
