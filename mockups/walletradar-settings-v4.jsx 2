/* ═══ NET PICKER ════════════════════════════════════════════ */
const NetPicker = ({selected,onChange}) => (
  <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:4}}>
    {NETS.map(n=>{
      const on=selected.includes(n.id);
      return (
        <button key={n.id} onClick={()=>onChange(on?selected.filter(x=>x!==n.id):[...selected,n.id])}
          style={{display:"flex",alignItems:"center",gap:5,padding:"5px 7px",borderRadius:5,
            background:on?n.color+"15":C.s3,border:`1px solid ${on?n.color+"50":C.border}`,
            color:on?n.color:C.sub,fontSize:10,fontWeight:600,transition:"all .1s"}}>
          <span style={{fontSize:12}}>{n.icon}</span>{n.label}
        </button>
      );
    })}
  </div>
);

/* ═══ WALLET ROW ════════════════════════════════════════════ */
const WalletRow = ({entry,index,colorIdx,onChange,onRemove,onPaste}) => {
  const [netsOpen,setNetsOpen] = useState(false);
  const ref = useRef();
  useEffect(()=>{ if(!entry.addr) ref.current?.focus(); },[]);
  const t=entry.addr.trim();
  const st=!t?"empty":isEVM(t)?"ok":"err";
  const col=COLORS[colorIdx%COLORS.length];
  return (
    <div className="aIn" style={{border:`1px solid ${st==="ok"?col+"30":C.borderHi}`,borderRadius:7,overflow:"hidden",transition:"border-color .15s",animationDelay:`${index*30}ms`}}>
      <div style={{display:"flex",alignItems:"stretch",background:C.s2}}>
        <div style={{width:3,background:col,flexShrink:0}}/>
        <div style={{width:30,display:"flex",alignItems:"center",justifyContent:"center",
          fontFamily:"'IBM Plex Mono',monospace",fontSize:10,color:C.muted,flexShrink:0}}>
          {String(index+1).padStart(2,"0")}
        </div>
        <input value={entry.label} onChange={e=>onChange({...entry,label:e.target.value})}
          placeholder="Label" maxLength={20}
          style={{width:108,flexShrink:0,padding:"10px 8px",fontSize:12,background:"transparent",
            borderRight:`1px solid ${C.border}`}}/>
        <div style={{flex:1,position:"relative",display:"flex",alignItems:"center"}}>
          <input ref={ref} value={entry.addr} onChange={e=>onChange({...entry,addr:e.target.value})}
            onPaste={e=>onPaste(e,index)} placeholder="0x… EVM address"
            spellCheck={false} autoComplete="off"
            style={{width:"100%",padding:"10px 32px 10px 12px",fontSize:12,
              fontFamily:"'IBM Plex Mono',monospace",background:"transparent"}}/>
          {st!=="empty"&&(
            <div style={{position:"absolute",right:9,pointerEvents:"none"}}>
              {st==="ok"?<Icon n="check" s={13} c={C.green}/>:<Icon n="x" s={13} c={C.red}/>}
            </div>
          )}
        </div>
        <button onClick={()=>setNetsOpen(o=>!o)} style={{
          flexShrink:0,display:"flex",alignItems:"center",gap:5,padding:"0 11px",
          borderLeft:`1px solid ${C.border}`,background:netsOpen?C.cyanDim:"transparent",
          color:netsOpen?C.cyan:C.sub,fontSize:10,fontWeight:600,transition:"all .12s",whiteSpace:"nowrap"}}>
          {entry.nets.length===NETS.length
            ?<span style={{fontSize:10,color:C.sub}}>All nets</span>
            :<div style={{display:"flex",gap:3}}>
               {entry.nets.slice(0,3).map(nid=>{const n=NETS.find(x=>x.id===nid);return n?<span key={nid} style={{fontSize:12,color:n.color}}>{n.icon}</span>:null;})}
               {entry.nets.length>3&&<span style={{fontSize:9,color:C.muted}}>+{entry.nets.length-3}</span>}
               {entry.nets.length===0&&<span style={{color:C.red,fontSize:10}}>none</span>}
             </div>
          }
          <div style={{transform:netsOpen?"rotate(180deg)":"none",transition:"transform .15s"}}>
            <Icon n="chev_d" s={10} c={netsOpen?C.cyan:C.sub}/>
          </div>
        </button>
        <button onClick={onRemove}
          style={{flexShrink:0,padding:"0 11px",borderLeft:`1px solid ${C.border}`,
            color:C.sub,display:"flex",alignItems:"center",transition:"color .1s,background .1s"}}
          onMouseOver={e=>{e.currentTarget.style.color=C.red;e.currentTarget.style.background=C.redDim}}
          onMouseOut={e=>{e.currentTarget.style.color=C.sub;e.currentTarget.style.background="transparent"}}>
          <Icon n="trash" s={12}/>
        </button>
      </div>
      {netsOpen&&(
        <div style={{padding:"10px 12px 11px",borderTop:`1px solid ${C.border}`,background:C.s1}}>
          <SL mb={7} action={
            <button onClick={()=>onChange({...entry,nets:entry.nets.length===NETS.length?[]:ALL_NETS})}
              style={{fontSize:9,color:C.sub,padding:"1px 6px",border:`1px solid ${C.border}`,borderRadius:3,background:C.s3}}>
              {entry.nets.length===NETS.length?"none":"all"}
            </button>}>Networks</SL>
          <NetPicker selected={entry.nets} onChange={nets=>onChange({...entry,nets})}/>
        </div>
      )}
      {st==="err"&&<div style={{display:"flex",alignItems:"center",gap:5,padding:"5px 12px",
        borderTop:`1px solid ${C.red}20`,background:C.redDim,fontSize:10,color:C.red}}>
        <Icon n="warn" s={10} c={C.red}/>Not a valid EVM address (0x + 40 hex chars)</div>}
    </div>
  );
};

