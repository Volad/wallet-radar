/* ═══ BYBIT FORM ════════════════════════════════════════════ */
const BybitForm = ({value,onChange,compact=false}) => {
  const [showSec,setShowSec] = useState(false);
  const [testing,setTesting] = useState(false);
  const [testResult,setTestResult] = useState(null); // null | 'ok' | 'err'
  const connected = !!(value?.api_key&&value?.api_secret);

  const handleTest = () => {
    if(!connected)return;
    setTesting(true);setTestResult(null);
    setTimeout(()=>{setTesting(false);setTestResult('ok');},1400);
  };

  return (
    <div style={{background:C.s1,border:`1px solid ${connected?C.green+"35":C.border}`,
      borderRadius:8,overflow:"hidden"}}>
      {/* Header */}
      <div style={{display:"flex",alignItems:"center",gap:11,padding:"10px 13px",
        borderBottom:`1px solid ${C.border}`}}>
        <div style={{width:32,height:32,borderRadius:7,flexShrink:0,background:"#F7A60018",
          border:"1px solid #F7A60035",display:"flex",alignItems:"center",justifyContent:"center",
          fontSize:14,fontWeight:800,color:"#F7A600",fontFamily:"'IBM Plex Mono',monospace"}}>B</div>
        <div style={{flex:1}}>
          <div style={{fontWeight:700,fontSize:12,display:"flex",alignItems:"center",gap:7,marginBottom:1}}>
            Bybit
            <Tag v="def">CEX</Tag>
            {connected&&<Tag v="green">Connected</Tag>}
          </div>
          <div style={{fontSize:10,color:C.sub}}>
            {connected?`${value.name||"Bybit"} · ${value.api_key?.slice(0,10)}…`:"Import trading history and P&L"}
          </div>
        </div>
        {connected&&(
          <button onClick={handleTest} disabled={testing} style={{
            display:"flex",alignItems:"center",gap:5,padding:"4px 10px",
            border:`1px solid ${testResult==='ok'?C.green+"44":C.border}`,borderRadius:5,
            background:testResult==='ok'?C.greenDim:C.s2,
            color:testResult==='ok'?C.green:C.sub,fontSize:10,fontWeight:600,transition:"all .12s"}}>
            {testing?<><Spin s={11} c={C.sub}/>Testing…</>
              :testResult==='ok'?<><Icon n="check" s={11} c={C.green}/>Connection OK</>
              :<><Icon n="test" s={11}/>Test</>}
          </button>
        )}
      </div>

      {/* Instructions (collapsible in compact mode) */}
      {!compact&&(
