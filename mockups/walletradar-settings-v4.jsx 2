/* ═══ EDIT: DATA SOURCES ════════════════════════════════════ */
const DataSources = ({session,onSaved}) => {
  const [wallets,   setWallets]  = useState(session.wallets);
  const [draft,     setDraft]    = useState([]);
  const [bybit,     setBybit]    = useState(session.bybit||{});
  const [family,    setFamily]   = useState(session.family);
  const [confirm,   setConfirm]  = useState(false);
  const [saving,    setSaving]   = useState(false);
  const [savedFlash,setSavedFlash]=useState(false);

  const handlePaste = (e,idx) => {
    const text=e.clipboardData.getData("text");
    const lines=text.split(/[\n,\s]+/).map(l=>l.trim()).filter(l=>l.length>10);
    if(lines.length<=1)return;
    e.preventDefault();
    const rows=lines.map(addr=>({...mkW(),addr}));
    setDraft(d=>{const c=[...d];c.splice(idx,1,...rows);return c.slice(0,10-wallets.length);});
  };

  // Detect changes
  const newValid  = draft.filter(w=>isEVM(w.addr.trim())&&w.nets.length>0);
  const famChanged = family!==session.family;
  const bybitChanged = JSON.stringify({k:bybit.api_key,s:bybit.api_secret})!==JSON.stringify({k:session.bybit?.api_key,s:session.bybit?.api_secret});

  const changes = [
    famChanged&&{label:`Accounting: ${session.family} → ${family}`,tag:family,tagV:"cyan"},
    newValid.length>0&&{label:`Add ${newValid.length} new wallet${newValid.length>1?"s":""}`,tag:"+"+newValid.length,tagV:"green"},
    bybitChanged&&bybit.api_key&&{label:"Update Bybit API credentials",tag:"Bybit",tagV:"amber"},
  ].filter(Boolean);

  const isDirty = changes.length>0;

  const handleConfirm = () => {
    setSaving(true);
    setTimeout(()=>{
      setSaving(false);setConfirm(false);setSavedFlash(true);
      setTimeout(()=>setSavedFlash(false),3000);
      onSaved({wallets:[...wallets,...newValid.map((w,i)=>({...w,id:Date.now()+i,status:"syncing"}))],bybit,family});
      setDraft([]);
    },1400);
  };

  return (
    <div style={{flex:1,overflow:"auto",padding:"22px 28px 100px",position:"relative"}}>
      {/* Header */}
      <div style={{display:"flex",alignItems:"flex-start",justifyContent:"space-between",marginBottom:22}}>
        <div>
          <div style={{fontWeight:800,fontSize:15,marginBottom:2}}>Data sources</div>
          <div style={{fontSize:11,color:C.sub}}>Wallets, integrations and accounting method</div>
        </div>
        <div style={{display:"flex",gap:8,alignItems:"center"}}>
          {savedFlash&&(
            <div className="aIn" style={{display:"flex",alignItems:"center",gap:6,padding:"6px 11px",
              background:C.greenDim,border:`1px solid ${C.greenMid}`,borderRadius:6}}>
              <Icon n="refresh" s={11} c={C.green}/>
              <span style={{fontSize:11,color:C.green,fontWeight:600}}>Pipeline restarted</span>
            </div>
          )}
          {isDirty&&!confirm&&(
            <button onClick={()=>setConfirm(true)} style={{
              display:"flex",alignItems:"center",gap:7,padding:"7px 16px",
              background:C.amberDim,border:`1px solid ${C.amberMid}`,borderRadius:6,
              color:C.amber,fontSize:11,fontWeight:700}}>
              <Icon n="warn" s={12} c={C.amber}/>Review changes ({changes.length})
            </button>
          )}
        </div>
      </div>

      {/* Wallets */}
      <section style={{marginBottom:22}}>
        <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:10}}>
          <Icon n="wallet" s={13} c={C.sub}/>
          <span style={{fontWeight:700,fontSize:13}}>Web3 wallets</span>
          <Tag v="def">{wallets.length}</Tag>
          <div style={{flex:1}}/>
          {!draft.length&&wallets.length<10&&(
            <button onClick={()=>setDraft([mkW()])} style={{
              display:"flex",alignItems:"center",gap:5,padding:"5px 12px",
              background:C.cyanDim,border:`1px solid ${C.cyanMid}`,borderRadius:5,
              color:C.cyan,fontSize:11,fontWeight:600}}>
              <Icon n="plus" s={10} c={C.cyan}/>Add wallet
            </button>
          )}
        </div>

        {/* Saved wallets — read-only rows */}
        <div style={{display:"flex",flexDirection:"column",gap:3}}>
          {wallets.map((w,i)=>(
            <div key={w.id} style={{display:"flex",alignItems:"stretch",background:C.s2,
              border:`1px solid ${C.borderHi}`,borderRadius:7,overflow:"hidden"}}>
              <div style={{width:3,background:COLORS[i%COLORS.length],flexShrink:0}}/>
              <div style={{width:30,display:"flex",alignItems:"center",justifyContent:"center",
                fontFamily:"'IBM Plex Mono',monospace",fontSize:10,color:C.muted,flexShrink:0}}>
                {String(i+1).padStart(2,"0")}
              </div>
              <div style={{width:110,flexShrink:0,padding:"9px 8px",fontSize:12,fontWeight:600,
                borderRight:`1px solid ${C.border}`,display:"flex",alignItems:"center"}}>
                {w.label||<span style={{color:C.muted,fontWeight:400}}>—</span>}
              </div>
              <div style={{flex:1,padding:"9px 12px",fontFamily:"'IBM Plex Mono',monospace",
                fontSize:10,color:C.sub,display:"flex",alignItems:"center"}}>{w.addr}</div>
              <div style={{flexShrink:0,display:"flex",gap:3,alignItems:"center",padding:"0 11px",
                borderLeft:`1px solid ${C.border}`}}>
                {w.nets.length===NETS.length
                  ?<span style={{fontSize:9,color:C.sub}}>All nets</span>
                  :w.nets.map(nid=>{const n=NETS.find(x=>x.id===nid);return n?<span key={nid} style={{fontSize:13,color:n.color}} title={n.label}>{n.icon}</span>:null;})
                }
              </div>
              <div style={{flexShrink:0,display:"flex",alignItems:"center",gap:5,padding:"0 10px",
                borderLeft:`1px solid ${C.border}`}}>
                <div style={{width:6,height:6,borderRadius:"50%",
                  background:w.status==="synced"?C.green:C.amber,
                  animation:w.status==="syncing"?"pulse 1.5s ease infinite":undefined}}/>
                <span className="mono" style={{fontSize:9,color:w.status==="synced"?C.green:C.amber}}>
                  {w.status}
                </span>
              </div>
              <button onClick={()=>setWallets(ws=>ws.filter(x=>x.id!==w.id))}
                style={{flexShrink:0,padding:"0 11px",borderLeft:`1px solid ${C.border}`,
                  color:C.sub,display:"flex",alignItems:"center",transition:"color .1s,background .1s"}}
                onMouseOver={e=>{e.currentTarget.style.color=C.red;e.currentTarget.style.background=C.redDim}}
                onMouseOut={e=>{e.currentTarget.style.color=C.sub;e.currentTarget.style.background="transparent"}}>
                <Icon n="trash" s={12}/>
              </button>
            </div>
          ))}
        </div>

        {/* Draft new wallets */}
        {draft.length>0&&(
          <div className="aIn" style={{marginTop:10}}>
            <div style={{fontSize:9,fontWeight:700,color:C.cyan,textTransform:"uppercase",
              letterSpacing:".12em",marginBottom:7,display:"flex",alignItems:"center",gap:6}}>
              <div style={{flex:1,height:1,background:C.cyanMid+"50"}}/>
              New wallets — pending save
              <div style={{flex:1,height:1,background:C.cyanMid+"50"}}/>
            </div>
            <div style={{display:"flex",flexDirection:"column",gap:5}}>
              {draft.map((w,i)=>(
                <WalletRow key={w._id} entry={w} index={wallets.length+i} colorIdx={wallets.length+i}
                  onChange={u=>setDraft(d=>d.map(x=>x._id===w._id?u:x))}
                  onRemove={()=>setDraft(d=>d.filter(x=>x._id!==w._id))}
                  onPaste={handlePaste}/>
              ))}
            </div>
            {draft.length<(10-wallets.length)&&(
              <button onClick={()=>setDraft(d=>[...d,mkW()])} style={{
                width:"100%",marginTop:6,padding:"7px",border:`1px dashed ${C.border}`,borderRadius:6,
                color:C.sub,fontSize:11,background:"transparent",display:"flex",
                alignItems:"center",justifyContent:"center",gap:5,transition:"all .12s"}}
                onMouseOver={e=>{e.currentTarget.style.borderColor=C.cyanMid;e.currentTarget.style.color=C.cyan}}
                onMouseOut={e=>{e.currentTarget.style.borderColor=C.border;e.currentTarget.style.color=C.sub}}>
                <Icon n="plus" s={10}/>Add another
              </button>
            )}
          </div>
        )}
      </section>

      <Divider my={0}/>

      {/* Integrations */}
      <section style={{marginTop:20,marginBottom:22}}>
        <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:10}}>
          <Icon n="link" s={13} c={C.sub}/>
          <span style={{fontWeight:700,fontSize:13}}>Integrations</span>
        </div>
        <BybitForm value={bybit} onChange={setBybit} compact/>
      </section>

      <Divider my={0}/>

      {/* Accounting */}
      <section style={{marginTop:20}}>
        <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:4}}>
          <Icon n="gear" s={13} c={C.sub}/>
          <span style={{fontWeight:700,fontSize:13}}>Accounting method</span>
          {famChanged&&<Tag v="amber">Changed</Tag>}
        </div>
        <div style={{fontSize:11,color:C.sub,marginBottom:12}}>
          Changing this restarts re-normalization for all wallets (~5–30 min).
        </div>
        <div style={{maxWidth:500}}>
          <AccountingPicker value={family} onChange={setFamily} showImpact={famChanged}/>
        </div>
      </section>

      {/* Confirmation */}
      {confirm&&(
        <ConfirmDrawer changes={changes} walletsCount={wallets.length+newValid.length}
          onCancel={()=>setConfirm(false)} onConfirm={handleConfirm} saving={saving}/>
      )}
    </div>
  );
};

/* ═══ GENERAL SETTINGS ══════════════════════════════════════ */
const GeneralSettings = () => {
  const [prefs,setPrefs] = useState({
    hideSmall:true, reconWarn:true, gasInBasis:true, crossWalletAvco:false,
    hideUnknownPrice:false, autoRefreshBalance:true, defaultRange:"1Y",
    clusterPx:28, toleranceE8:true,
  });
  const set = (k,v) => setPrefs(p=>({...p,[k]:v}));

  const TogRow = ({k,label,desc,disabled}) => (
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",
      padding:"10px 13px",background:C.s2,border:`1px solid ${C.border}`,borderRadius:7,
      opacity:disabled?.5:1}}>
      <div style={{flex:1,paddingRight:12}}>
        <div style={{fontSize:12,fontWeight:600,marginBottom:desc?2:0}}>{label}</div>
        {desc&&<div style={{fontSize:10,color:C.sub,lineHeight:1.5}}>{desc}</div>}
      </div>
      <label className="toggle" style={{flexShrink:0,marginTop:1}}>
        <input type="checkbox" checked={prefs[k]} onChange={e=>set(k,e.target.checked)} disabled={disabled}/>
        <span className="tsl"/>
      </label>
    </div>
  );

  const SelectRow = ({label,desc,k,options}) => (
    <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",
      padding:"10px 13px",background:C.s2,border:`1px solid ${C.border}`,borderRadius:7}}>
      <div style={{flex:1,paddingRight:12}}>
        <div style={{fontSize:12,fontWeight:600,marginBottom:desc?2:0}}>{label}</div>
        {desc&&<div style={{fontSize:10,color:C.sub,lineHeight:1.5}}>{desc}</div>}
      </div>
      <div style={{position:"relative",flexShrink:0}}>
        <select value={prefs[k]} onChange={e=>set(k,e.target.value)}
          style={{appearance:"none",background:C.s3,border:`1px solid ${C.border}`,borderRadius:5,
            color:C.text,padding:"5px 24px 5px 9px",fontSize:11,cursor:"pointer"}}>
          {options.map(o=><option key={o.value} value={o.value}>{o.label}</option>)}
        </select>
        <div style={{position:"absolute",right:7,top:"50%",transform:"translateY(-50%)",pointerEvents:"none"}}>
          <Icon n="chev_d" s={10} c={C.sub}/>
        </div>
      </div>
    </div>
  );

  return (
    <div style={{flex:1,overflow:"auto",padding:"22px 28px 40px"}}>
      <div style={{fontWeight:800,fontSize:15,marginBottom:2}}>General</div>
      <div style={{fontSize:11,color:C.sub,marginBottom:20}}>Display and calculation preferences</div>

      <div style={{maxWidth:540,display:"flex",flexDirection:"column",gap:20}}>

        {/* Display */}
        <div>
          <SL mb={8}>Display</SL>
          <div style={{display:"flex",flexDirection:"column",gap:4}}>
            <TogRow k="hideSmall"   label="Hide assets below $0.50"        desc="Filters dust from the token list. Realisable P&L still tracked."/>
            <TogRow k="hideUnknownPrice" label="Hide events with unknown price" desc="Hides transactions where price source is UNKNOWN from event log."/>
            <SelectRow k="defaultRange" label="Default chart range"
              desc="Initial time window shown on Move Basis and portfolio charts."
              options={[{value:"1M",label:"1 Month"},{value:"3M",label:"3 Months"},{value:"6M",label:"6 Months"},{value:"1Y",label:"1 Year"},{value:"ALL",label:"All time"}]}/>
          </div>
        </div>

        {/* Accounting */}
        <div>
          <SL mb={8}>Accounting</SL>
          <div style={{display:"flex",flexDirection:"column",gap:4}}>
            <TogRow k="gasInBasis" label="Include gas in cost basis"
              desc="Gas fees on BUY events are added to the average cost. Recommended for accurate P&L."/>
            <TogRow k="crossWalletAvco" label="Cross-wallet AVCO by default"
              desc="Show combined AVCO across all session wallets instead of per-wallet. Always computed on-request, never stored."/>
            <TogRow k="toleranceE8" label="Use ε=1e-8 reconciliation tolerance"
              desc="Amounts differing by less than 0.00000001 are treated as MATCH. Prevents dust mismatches."/>
          </div>
        </div>

        {/* Balance & Sync */}
        <div>
          <SL mb={8}>Balance & Sync</SL>
          <div style={{display:"flex",flexDirection:"column",gap:4}}>
            <TogRow k="autoRefreshBalance" label="Auto-refresh on-chain balance"
              desc="Poll current wallet balances every 10 minutes for reconciliation. Disable to reduce RPC calls."/>
            <TogRow k="reconWarn" label="Show reconciliation warnings"
              desc="Display ⚠ when on-chain balance doesn't match derived quantity. Prompts manual compensating transaction."/>
          </div>
        </div>

        {/* Chart */}
        <div>
          <SL mb={8}>Chart</SL>
          <div style={{display:"flex",flexDirection:"column",gap:4}}>
            <div style={{padding:"10px 13px",background:C.s2,border:`1px solid ${C.border}`,borderRadius:7}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
                <div>
                  <div style={{fontSize:12,fontWeight:600,marginBottom:2}}>Event cluster radius</div>
                  <div style={{fontSize:10,color:C.sub}}>Pixel proximity threshold for grouping nearby events on Move Basis chart.</div>
                </div>
                <span className="mono" style={{fontSize:13,fontWeight:700,color:C.cyan}}>{prefs.clusterPx}px</span>
              </div>
              <input type="range" min={10} max={60} value={prefs.clusterPx}
                onChange={e=>set("clusterPx",parseInt(e.target.value))}
                style={{width:"100%",accentColor:C.cyan}}/>
              <div style={{display:"flex",justifyContent:"space-between",marginTop:3}}>
                <span style={{fontSize:9,color:C.muted}}>10 — dense</span>
                <span style={{fontSize:9,color:C.muted}}>60 — aggressive</span>
              </div>
            </div>
          </div>
        </div>

        {/* About / version */}
        <div style={{padding:"12px 13px",background:C.s2,border:`1px solid ${C.border}`,borderRadius:7}}>
          <SL mb={8}>About</SL>
          {[
            {l:"Version",v:"0.9.1-beta"},
            {l:"Accounting engine",v:"AVCO replay v2.1"},
            {l:"Supported networks",v:"9 EVM"},
            {l:"Data sources",v:"Explorer-first + CoinGecko"},
          ].map(row=>(
            <div key={row.l} style={{display:"flex",justifyContent:"space-between",padding:"3px 0",
              borderBottom:`1px solid ${C.border}`,fontSize:11}}>
              <span style={{color:C.sub}}>{row.l}</span>
              <span className="mono" style={{fontSize:10,color:C.text}}>{row.v}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
};

/* ═══ APP SHELL ═════════════════════════════════════════════ */
const NAV_ITEMS = [
  {id:"tokens",icon:"tokens",label:"Tokens",color:"#22d3ee"},
  {id:"lp",    icon:"lp",   label:"LP",    color:"#60a5fa"},
  {id:"lending",icon:"lending",label:"Lending",color:"#34d399"},
  {id:"staking",icon:"staking",label:"Staking",color:"#fbbf24",soon:true},
];
const SETTINGS_NAV = [
  {id:"sources",icon:"wallet",label:"Data sources"},
  {id:"general",icon:"gear",  label:"General"},
];

export default function App() {
  const [page,    setPage]    = useState("settings");
  const [stTab,   setStTab]   = useState("sources");
  const [session, setSession] = useState(null);  // null = empty
  const isSettings = page==="settings";

  const handleWizardDone = (data) => {
    setSession({
      wallets: data.wallets.map((w,i)=>({...w,id:Date.now()+i,status:"syncing"})),
      bybit: data.bybit,
      family: data.family,
    });
  };

  return (
    <div style={{height:"100vh",display:"flex",flexDirection:"column",background:C.bg,overflow:"hidden"}}>
      <style>{G}</style>

      {/* TOP BAR */}
      <div style={{flexShrink:0,height:46,borderBottom:`1px solid ${C.border}`,
        background:C.s1,display:"flex",alignItems:"center",gap:12,padding:"0 14px"}}>
        <div style={{display:"flex",alignItems:"center",gap:7}}>
          <div style={{width:24,height:24,background:C.cyan,borderRadius:5,
            display:"flex",alignItems:"center",justifyContent:"center",fontSize:12,flexShrink:0}}>⚡</div>
          <span style={{fontWeight:800,fontSize:13,letterSpacing:"-.02em"}}>WalletRadar</span>
        </div>
        <div style={{width:1,height:16,background:C.border,flexShrink:0}}/>
        {session
          ? [{l:"Portfolio",v:"$47.2k",c:C.text},{l:"Unrealised",v:"+7.4%",c:C.green},{l:"Realised",v:"+$1.9k",c:C.green}]
              .map(m=>(
                <div key={m.l} style={{display:"flex",gap:5,alignItems:"baseline"}}>
                  <span style={{fontSize:9,color:C.sub}}>{m.l}</span>
                  <span className="mono" style={{fontSize:13,fontWeight:700,color:m.c}}>{m.v}</span>
                </div>
              ))
          : <span style={{fontSize:11,color:C.sub,fontStyle:"italic"}}>Configure your wallets to get started</span>
        }
        <div style={{flex:1}}/>
        {/* Wallet chips — no Add Wallet button */}
        {session&&(
          <div style={{display:"flex",gap:5,alignItems:"center",flexShrink:0}}>
            <span style={{fontSize:9,color:C.muted,marginRight:2}}>Connected</span>
            {session.wallets.slice(0,4).map((w,i)=>(
              <div key={i} style={{display:"flex",alignItems:"center",gap:4,padding:"3px 8px",
                background:C.s2,border:`1px solid ${C.border}`,borderRadius:5}}>
                <div style={{width:6,height:6,borderRadius:"50%",background:COLORS[i%COLORS.length],
                  animation:w.status==="syncing"?"pulse 1.5s ease infinite":undefined}}/>
                <span className="mono" style={{fontSize:9,color:C.sub}}>{shortA(w.addr)}</span>
                <span style={{fontSize:9,color:C.sub}}>· {w.label||`W${i+1}`}</span>
              </div>
            ))}
            {session.wallets.length>4&&<span style={{fontSize:10,color:C.sub}}>+{session.wallets.length-4} more</span>}
            {session.bybit?.api_key&&(
              <div style={{display:"flex",alignItems:"center",gap:4,padding:"3px 8px",
                background:"#F7A60010",border:"1px solid #F7A60030",borderRadius:5}}>
                <div style={{width:6,height:6,borderRadius:2,background:"#F7A600"}}/>
                <span style={{fontSize:9,color:"#F7A600",fontFamily:"'IBM Plex Mono',monospace"}}>Bybit</span>
              </div>
            )}
          </div>
        )}
      </div>

      {/* BODY */}
      <div style={{flex:1,display:"flex",overflow:"hidden"}}>

        {/* ICON NAV */}
        <div style={{width:44,flexShrink:0,borderRight:`1px solid ${C.border}`,
          display:"flex",flexDirection:"column",alignItems:"center",padding:"6px 0",gap:2}}>
          {NAV_ITEMS.map(s=>(
            <button key={s.id} onClick={()=>!s.soon&&session&&setPage(s.id)}
              title={s.label+(s.soon?" (soon)":"")}
              style={{
                width:36,height:36,borderRadius:7,display:"flex",alignItems:"center",justifyContent:"center",
                background:page===s.id&&!isSettings?s.color+"20":"transparent",
                border:`1px solid ${page===s.id&&!isSettings?s.color+"44":"transparent"}`,
                color:page===s.id&&!isSettings?s.color:(!session||s.soon)?C.muted:C.sub,
                opacity:(!session||s.soon)?.35:1,cursor:(!session||s.soon)?"not-allowed":"pointer",
                transition:"all .12s",position:"relative",
              }}>
              <Icon n={s.icon} s={15} c={page===s.id&&!isSettings?s.color:(!session||s.soon)?C.muted:C.sub}/>
              {page===s.id&&!isSettings&&<div style={{position:"absolute",left:0,top:"20%",
                width:2,height:"60%",background:s.color,borderRadius:"0 2px 2px 0"}}/>}
            </button>
          ))}
          <div style={{flex:1}}/>
          <div style={{paddingBottom:4}}>
            <button onClick={()=>setPage("settings")} title="Settings" style={{
              width:36,height:36,borderRadius:7,display:"flex",alignItems:"center",justifyContent:"center",
              background:isSettings?C.cyanDim:"transparent",
              border:`1px solid ${isSettings?C.cyanMid:"transparent"}`,
              color:isSettings?C.cyan:C.sub,transition:"all .12s",position:"relative"}}>
              <Icon n="gear" s={15} c={isSettings?C.cyan:C.sub}/>
              {isSettings&&<div style={{position:"absolute",left:0,top:"20%",
                width:2,height:"60%",background:C.cyan,borderRadius:"0 2px 2px 0"}}/>}
            </button>
          </div>
        </div>

        {/* SETTINGS */}
        {isSettings&&(
          <div style={{flex:1,display:"flex",overflow:"hidden",background:C.s1,position:"relative"}}>
            {!session
              ? <Wizard onFinish={handleWizardDone}/>
              : <>
                  {/* Settings sidebar nav */}
                  <div style={{width:196,flexShrink:0,borderRight:`1px solid ${C.border}`,
                    display:"flex",flexDirection:"column"}}>
                    <div style={{padding:"12px 14px 10px",borderBottom:`1px solid ${C.border}`,
                      display:"flex",alignItems:"center",gap:7}}>
                      <Icon n="gear" s={13} c={C.sub}/>
                      <span style={{fontWeight:700,fontSize:13}}>Settings</span>
                    </div>
                    <div style={{flex:1,overflowY:"auto",padding:"6px 0"}}>
                      {SETTINGS_NAV.map(s=>(
                        <button key={s.id} onClick={()=>setStTab(s.id)} style={{
                          width:"100%",display:"flex",alignItems:"center",gap:8,padding:"8px 14px",
                          background:stTab===s.id?C.cyanDim:"transparent",
                          borderLeft:`2px solid ${stTab===s.id?C.cyan:"transparent"}`,
                          color:stTab===s.id?C.cyan:C.sub,fontSize:12,
                          fontWeight:stTab===s.id?600:400,transition:"all .12s",textAlign:"left"}}>
                          <Icon n={s.icon} s={12} c={stTab===s.id?C.cyan:C.sub}/>
                          {s.label}
                        </button>
                      ))}
                      <Divider my={6}/>
                      {["Appearance","Notifications","About"].map(l=>(
                        <button key={l} style={{width:"100%",padding:"7px 14px",
                          textAlign:"left",color:C.muted,fontSize:11}}>{l}</button>
                      ))}
                    </div>
                  </div>

                  {stTab==="sources"&&(
                    <DataSources session={session}
                      onSaved={updated=>setSession(s=>({...s,...updated}))}/>
                  )}
                  {stTab==="general"&&<GeneralSettings/>}
                </>
            }
          </div>
        )}

        {/* OTHER PAGES */}
        {!isSettings&&(
          <div style={{flex:1,display:"flex",alignItems:"center",justifyContent:"center",
            color:C.sub,fontSize:12,flexDirection:"column",gap:8}}>
            <div>{NAV_ITEMS.find(s=>s.id===page)?.label} view</div>
            <button onClick={()=>setPage("settings")} style={{fontSize:11,color:C.cyan,
              padding:"5px 12px",border:`1px solid ${C.cyanMid}`,borderRadius:5,background:C.cyanDim}}>
              ← Settings ⚙
            </button>
          </div>
        )}
      </div>
    </div>
  );
}
