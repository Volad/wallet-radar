const WIZARD_STEPS = [
  {id:"wallets",     icon:"wallet",label:"Wallets",      desc:"Add EVM addresses to track"},
  {id:"integrations",icon:"link",  label:"Integrations", desc:"Optional exchange connections"},
  {id:"accounting",  icon:"gear",  label:"Accounting",   desc:"Cost basis method"},
  {id:"review",      icon:"check", label:"Review",       desc:"Confirm & start indexing"},
];

