  {id:"BSC", icon:"◈",label:"BNB",      color:"#F0B90B"},
  {id:"AVAX",icon:"▲",label:"Avalanche",color:"#E84142"},
  {id:"MNT", icon:"◉",label:"Mantle",   color:"#60a5fa"},
